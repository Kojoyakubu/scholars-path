# Frontend OAuth config
# Copy this file to .env (or .env.local) and fill values.

# Must be the same Web OAuth client ID configured in Google Cloud Console.
VITE_GOOGLE_CLIENT_ID=

# Base URL used to build OAuth callback redirect.
# Dev example: http://localhost:5173
# Prod example: https://lernex.onrender.com
VITE_APP_URL=

# API base URL (already used by app if provided)
VITE_API_URL=
